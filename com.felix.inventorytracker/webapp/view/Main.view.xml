<mvc:View
	controllerName="com.felix.inventoryTracker.controller.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	core:require="{
		formatter: 'com/felix/inventoryTracker/model/formatter'
	}">

	<Page
		title="{i18n>appTitle}"
		id="page"
  >
  <customHeader>
    <Toolbar>
      <Title text="Items"/>
      <ToolbarSpacer/>
      <Button text="Create" press=".onCreate"/>
    </Toolbar>
  </customHeader>
		<content>
      <core:Fragment fragmentName="com.felix.inventoryTracker.view.ItemTable" type="XML"/>
		</content>
	</Page>

</mvc:View>
