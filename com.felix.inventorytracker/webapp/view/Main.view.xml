<mvc:View
	controllerName="com.felix.inventoryTracker.controller.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	core:require="{
		formatter: 'com/felix/inventoryTracker/model/formatter'
	}">

	<Page
		title="{i18n>appTitle}"
		id="page"
  >
		<content>
      <mvc:XMLView viewName="com.felix.inventoryTracker.view.ItemForm"></mvc:XMLView>
      <mvc:XMLView viewName="com.felix.inventoryTracker.view.ItemTable"></mvc:XMLView>
		</content>
	</Page>

</mvc:View>
