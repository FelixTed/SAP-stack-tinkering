<mvc:View
	controllerName="com.felix.inventoryTracker.controller.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	core:require="{
		formatter: 'com/felix/inventoryTracker/model/formatter'
	}">

	<Page
		title="{i18n>appTitle}"
		id="page">
		<content>
			<Table
      id="itemsTable"
      items="{items>/Item}"
      >
      <columns>
        <Column >
          <header><Text text="Name"></Text></header>
        </Column>
        <Column >
          <header><Text text="Quantity"></Text></header>
        </Column>
      </columns>
      <items>
          <ColumnListItem>
            <cells>
                <Text text="{items>name}" />
                <Text text="{items>quantity}" />
            </cells>
          </ColumnListItem>
      </items>
       </Table>
		</content>
	</Page>

</mvc:View>
