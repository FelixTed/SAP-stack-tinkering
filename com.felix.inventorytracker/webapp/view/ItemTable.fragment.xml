<core:FragmentDefinition
  xmlns='sap.m'
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:core="sap.ui.core"
  showNavButton="true"
>
<Table
      itemPress=".onItemPress"
      headerText="Items"
      id="itemsTable"
      items="{
        path: 'items>/Item',
        sorter:
          [{path:'quantity'}, {path: 'location', descending: true}]

      }"
      >
      <headerToolbar>
        <Toolbar>
          <Label id="tableHeader" text="Items toolbar"/>
          <ToolbarSpacer />
          <SearchField id="searchField" width="auto" search=".onFilterPosts" />
        </Toolbar>
      </headerToolbar>
      <columns>
        <Column >
          <header><Text text="Name"></Text></header>
        </Column>
        <Column >
          <header><Text text="Quantity"></Text></header>
        </Column>
        <Column >
          <header><Text text="Location"></Text></header>
        </Column>
        <Column >
          <header><Text text="Link"></Text></header>
        </Column>
      </columns>
      <items>
          <ColumnListItem type="Navigation">
            <cells>
                <Text text="{items>name}" />
                <Text text="{items>quantity}" />
                <Text text="{items>location}"></Text>
                <Link text="Get {items>name}" href="{items>url}"></Link>
            </cells>
          </ColumnListItem>
      </items>
</Table>
</core:FragmentDefinition>

