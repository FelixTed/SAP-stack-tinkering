<mvc:View
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
  controllerName="com.felix.inventoryTracker.controller.Item"
  xmlns:form="sap.ui.layout.form">


  <Page title="{name}">
    <content>
      <form:SimpleForm editable="false">

        <Label text="Name"/>
        <Text text="{items>name}" />

        <Label text="Category"/>
        <Text text="{items>category}" />

        <Label text="Quantity"/>
        <Text text="{items>quantity}" />

        <Label text="Location"/>
        <Text text="{items>location}" />

        <Label text="Note"/>
        <Text text="{items>note}" />

        <Label text="URL"/>
        <Link text="{items>url}" href="{items>url}" target="_blank"/>

      </form:SimpleForm>
      <Button
        text="Delete"
        type="Reject"
        press=".onDelete"
      />
    </content>
  </Page>

</mvc:View>
