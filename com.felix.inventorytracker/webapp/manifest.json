{
	"_version": "1.12.0",

	"sap.app": {
		"id": "com.felix.inventoryTracker",
		"type": "application",
		"i18n": "i18n/i18n.properties",
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
    "dataSources": {
      "itemsRemote":{
        "uri": "/odata/v4/catalogue/",
        "type": "OData",
        "settings": {
          "headers": {
            "Authorization": "Basic YWxpY2U6"
          },
          "odataVersion": "4.0"
        }
      },
      "locationsRemote":{
        "uri": "/odata/v4/location/",
        "type": "OData",
        "settings": {
          "headers": {
            "Authorization": "Basic YWxpY2U6"
          },
          "odataVersion": "4.0"
        }
      }
    },
		"applicationVersion": {
			"version": "${version}"
		},
		"sourceTemplate": {
			"id": "generator-ui5-app",
			"version": "1.1.0"
		}
	},

	"sap.ui": {
		"technology": "UI5",
		"icons": {},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},

	"sap.ui5": {
		"rootView": {
			"viewName": "com.felix.inventoryTracker.view.App",
			"type": "XML",
			"id": "app"
		},

		"dependencies": {
			"minUI5Version": "1.145.0",
			"libs": {
				"sap.ui.core": {},
				"sap.m": {},
        "sap.ui.mdc": {},
        "sap.ui.layout": {}
			}
		},

		"handleValidation": true,

		"contentDensities": {
			"compact": true,
			"cozy": true
		},

		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "com.felix.inventoryTracker.i18n.i18n",
					"supportedLocales": ["","en", "de"],
					"fallbackLocale": "",
					"async": true
				}
			},
      "items": {
        "type": "sap.ui.model.odata.v4.ODataModel",
        "dataSource": "itemsRemote",
        "settings": {
          "operationMode": "Server"
        }
      },
      "locations": {
        "type": "sap.ui.model.odata.v4.ODataModel",
        "dataSource": "locationsRemote",
        "settings": {
          "operationMode": "Server"
        }
      },
      "itemUIErrors": {
        "type": "sap.ui.model.json.JSONModel",
        "settings": {
          "data": {
            "name": "",
            "quantiy": "",
            "category": "",
            "location": "",
            "url": ""
          }
        }
      }
		},

		"routing": {
			"config": {
				"routerClass": "sap.m.routing.Router",
				"viewType": "XML",
				"viewPath": "com.felix.inventoryTracker.view",
				"controlId": "app",
				"controlAggregation": "pages"
			},
			"routes": [
				{
					"pattern": "",
					"name": "main",
					"target": "main"
				},
        {
          "pattern": "new",
          "name": "new-item",
          "target": "new-item"
        }
			],
			"targets": {
				"main": {
					"viewId": "main",
					"viewName": "Main"
				},
        "new-item": {
          "viewId": "new-item",
          "viewName": "NewItem"
        }
			}
		}
	}
}
